{
  // Dev Container 显示名称，便于在 Codespaces/VS Code 中识别
  "name": "PyTorch Research",

  // 基础镜像：官方 Python 开发容器，选择 Python 3.11
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",

  // Codespaces 创建后执行：安装常用系统工具，并在 requirements.txt 存在时执行 pip 安装
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y git wget vim tmux && if [ -f requirements.txt ]; then python -m pip install --upgrade pip && python -m pip install -r requirements.txt; fi",

  // VS Code 自定义：预装常用 Python 开发扩展
  "customizations": {
    // 编辑器相关设置与扩展
    "vscode": {
      // 预装 Python、Pylance、Jupyter 等常用扩展
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  }
}